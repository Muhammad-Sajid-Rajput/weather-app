# Required
WEATHER_API_KEY=your_weatherapi_key_here

# Server
PORT=5000
NODE_ENV=production

# Optional — separate frontend URL (only if API and UI are on different domains)
# CLIENT_URL=https://your-frontend.com

# Rate limiting (per IP, per 15 min by default)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Optional — only if frontend is hosted separately from the API
# VITE_API_URL=https://your-api.com
